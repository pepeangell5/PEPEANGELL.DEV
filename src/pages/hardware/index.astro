---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HardwareWiki from "../../components/HardwareWiki.astro";
import hardwareItems from "../../data/hardware-wiki.generated.json";
---

<BaseLayout
  title="Hardware Wiki"
  description="Wiki de componentes usados en los proyectos PepeAngell Labs: ESP32, pantallas, modulos RF, energia, cables y prototipado."
>
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Hardware wiki</p>
        <h1>Componentes del laboratorio</h1>
        <p>
          Lista tipo wiki de componentes, modulos, pantallas, energia y prototipado usados en los proyectos. Abre cada
          componente para ver descripcion, imagen, voltaje, uso tipico y advertencias.
        </p>
      </div>
      <HardwareWiki items={hardwareItems} />
    </div>
  </section>
</BaseLayout>
