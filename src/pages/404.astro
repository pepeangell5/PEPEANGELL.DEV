---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404" description="Pagina no encontrada en PepeAngell Labs.">
  <section class="section">
    <div class="container project-detail">
      <p class="eyebrow">404</p>
      <h1>Pagina no encontrada</h1>
      <p>La ruta no existe o todavia no se ha publicado. Puedes volver al inicio o explorar los proyectos.</p>
      <div class="button-row">
        <a class="button primary" href="/">Inicio</a>
        <a class="button" href="/projects/">Proyectos</a>
      </div>
    </div>
  </section>
</BaseLayout>
