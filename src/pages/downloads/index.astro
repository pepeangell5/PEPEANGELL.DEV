---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DownloadsExplorer from "../../components/DownloadsExplorer.astro";
import downloads from "../../data/downloads.generated.json";
---

<BaseLayout
  title="Descargas"
  description="Descargas directas de firmware, binarios, Web Flashers, releases y ZIP completos de repositorios de PepeAngell Labs."
>
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Firmware downloads</p>
        <h1>Descargas de proyectos y repos</h1>
        <p>
          Accesos directos a Web Flashers, binarios finales, releases y ZIP completos. Los repos nuevos se agregan
          automaticamente aunque todavia no tengan flasher detectado.
        </p>
      </div>

      <div class="notice">
        <strong>Recomendacion:</strong> si el proyecto tiene Web Flasher, usa primero esa opcion. El binario final es
        el mismo archivo que usa el flasher para instalar el firmware.
      </div>

      <DownloadsExplorer downloads={downloads} />
    </div>
  </section>
</BaseLayout>
