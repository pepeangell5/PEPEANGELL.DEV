---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FlasherCard from "../../components/FlasherCard.astro";
import flashers from "../../data/flashers.generated.json";
---

<BaseLayout
  title="Web Flashers"
  description="Web flashers detectados automaticamente para firmware educativo en hardware compatible de PepeAngell Labs."
>
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Web flashers</p>
        <h1>Flashers para hardware compatible</h1>
        <p>
          Tarjetas preparadas para enlazar firmware y flasheadores web detectados desde GitHub Pages. Usar solo con
          placas, pantallas y modulos compatibles.
        </p>
      </div>
      <div class="grid cards">
        {flashers.map((flasher) => <FlasherCard flasher={flasher} />)}
      </div>
    </div>
  </section>
</BaseLayout>
