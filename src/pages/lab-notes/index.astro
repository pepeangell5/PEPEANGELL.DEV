---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Noticias"
  description="La seccion de notas fue reemplazada por noticias recientes sobre firmware, gadgets, Flipper y hardware hacking."
>
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Seccion actualizada</p>
        <h1>Notas ahora es Noticias</h1>
        <p>
          La seccion de notas fue sustituida por un feed de noticias recientes sobre firmware, gadgets, Flipper,
          RF, WiFi/BLE, ESP32 y ciberseguridad.
        </p>
      </div>
      <div class="button-row">
        <a class="button primary" href="/news/">Ir a Noticias</a>
      </div>
    </div>
  </section>
</BaseLayout>
