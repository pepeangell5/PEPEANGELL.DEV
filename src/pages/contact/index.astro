---
import BaseLayout from "../../layouts/BaseLayout.astro";

const telegramChannelUrl = "https://t.me/+PnOGmQQDL05kN2Ix";
const telegramGroupUrl = "https://t.me/esp32_tools";
---

<BaseLayout
  title="Contact"
  description="Enlaces de contacto para PepeAngell Labs: GitHub, Instagram, Facebook, Telegram y comunidad ESP32 Tools."
>
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Contact</p>
        <h1>Contacto y enlaces</h1>
        <p>Enlaces oficiales para seguir proyectos, repositorios y actualizaciones de PepeAngell Labs.</p>
      </div>
      <div class="grid cards">
        <article class="card">
          <h3>GitHub</h3>
          <p>Repositorios publicos, firmware, notas y proyectos.</p>
          <a class="button primary" href="https://github.com/pepeangell5" target="_blank" rel="noreferrer noopener">Open GitHub</a>
        </article>
        <article class="card highlight">
          <h3>Canal de Telegram</h3>
          <p>Avisos, lanzamientos, publicaciones y novedades de PepeAngell Labs.</p>
          <a class="button primary" href={telegramChannelUrl} target="_blank" rel="noreferrer noopener">Abrir canal</a>
        </article>
        <article class="card">
          <h3>Grupo de Telegram</h3>
          <p>Comunidad ESP32 Tools para dudas, avances, pruebas y conversacion tecnica.</p>
          <a class="button primary" href={telegramGroupUrl} target="_blank" rel="noreferrer noopener">Abrir grupo</a>
        </article>
        <article class="card">
          <h3>Instagram</h3>
          <p>Updates visuales, avances de laboratorio y publicaciones cortas de proyectos.</p>
          <a class="button primary" href="https://instagram.com/esp32_tools" target="_blank" rel="noreferrer noopener">Open Instagram</a>
        </article>
        <article class="card">
          <h3>Facebook</h3>
          <p>Comunidad y publicaciones relacionadas con ESP32 Tools.</p>
          <a class="button primary" href="https://facebook.com/esp32-tools" target="_blank" rel="noreferrer noopener">Open Facebook</a>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
