---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact"
  description="Enlaces de contacto para PepeAngell Labs: GitHub, Instagram, Facebook, YouTube y email."
>
  <section class="section">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Contact</p>
        <h1>Contacto y enlaces</h1>
        <p>Pagina preparada para usar como enlace principal hacia repos, redes y futuros canales publicos.</p>
      </div>
      <div class="grid cards">
        <article class="card">
          <h3>GitHub</h3>
          <p>Repositorios publicos, firmware, notas y proyectos.</p>
          <a class="button primary" href="https://github.com/pepeangell5" rel="noreferrer">Open GitHub</a>
        </article>
        <article class="card">
          <h3>Instagram</h3>
          <p>Placeholder para perfil publico.</p>
          <a class="button" href="#">Instagram placeholder</a>
        </article>
        <article class="card">
          <h3>Facebook</h3>
          <p>Placeholder para pagina o perfil publico.</p>
          <a class="button" href="#">Facebook placeholder</a>
        </article>
        <article class="card">
          <h3>YouTube</h3>
          <p>Placeholder para videos, demos y notas de proyectos.</p>
          <a class="button" href="#">YouTube placeholder</a>
        </article>
        <article class="card">
          <h3>Email</h3>
          <p>Placeholder para correo publico de contacto.</p>
          <a class="button" href="mailto:placeholder@example.com">Email placeholder</a>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
