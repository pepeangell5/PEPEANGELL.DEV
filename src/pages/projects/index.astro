    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Apoyo | PepeAngell Labs</title>
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content={`0; url=${supportUrl}`} />
    <link rel="canonical" href="https://pepeangell.dev/support/" />
  </head>
  <body>
    <p><a href={supportUrl}>Ir a Apoyo</a></p>
  </body>
</html>
