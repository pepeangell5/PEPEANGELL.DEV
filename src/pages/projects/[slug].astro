---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Badge from "../../components/Badge.astro";
import DisclaimerBanner from "../../components/DisclaimerBanner.astro";
import { sitePath } from "../../utils/paths";
import projects from "../../data/projects.json";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
---

<BaseLayout
  title={project.name}
  description={`${project.name}: proyecto educativo de PepeAngell Labs para hardware, firmware y pruebas controladas.`}
>
  <section class="section">
    <div class="container project-detail">
      <p class="eyebrow">Project detail</p>
      <h1>{project.name}</h1>
      <p class="status">{project.status}</p>
      <p>{project.details}</p>
      <div class="badge-row">
        {project.tags.map((tag) => <Badge label={tag} />)}
      </div>
      <div class="section compact">
        <DisclaimerBanner />
      </div>
      <div class="button-row">
        <a class="button primary" href={sitePath("/projects/")}>Back to projects</a>
        {project.github_url && <a class="button" href={project.github_url} rel="noreferrer">GitHub</a>}
        {project.flasher_url && <a class="button" href={project.flasher_url}>Web Flasher</a>}
      </div>
    </div>
  </section>
</BaseLayout>
