---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DisclaimerBanner from "../../components/DisclaimerBanner.astro";
import { sitePath } from "../../utils/paths";

const paypalUrl = "https://www.paypal.com/paypalme/pepeangell";
const telegramChannelUrl = "https://t.me/+PnOGmQQDL05kN2Ix";
const telegramGroupUrl = "https://t.me/esp32_tools";

const products = [
  {
    slug: "rf-kill-esp32-devkit",
    name: "RF-KILL ESP32 DevKit Kit",
    status: "Kit programado",
    board: "ESP32 DevKit 30 pines",
    firmware: "RF-KILL ESP32-WROOM DevKit V2.0",
    repoUrl: "https://github.com/pepeangell5/RF-KILL-ESP32-DEVKIT",
    description:
      "Kit fisico basado en ESP32-WROOM DevKit con firmware RF-KILL instalado para demostracion academica, laboratorio RF controlado y practicas autorizadas.",
    image: "/assets/shop/esp32-devkit-kit.jpg",
    imageAlt: "Kit RF-KILL con ESP32 DevKit 30 pines y dos modulos NRF24 PA+LNA con antenas",
    parts: [
      "ESP32-WROOM DevKit 30 pines",
      "2x nRF24L01+ PA+LNA",
      "Bus SPI compartido para ambos modulos",
      "Bateria 3V",
      "Modulo de carga",
      "Step-up a 5V",
      "Firmware RF-KILL instalado"
    ],
    note: "Formato clasico, comodo para pruebas de mesa, modificaciones y laboratorio controlado.",
    price: 0,
    currency: "USD",
    stock: 0,
    is_available: false
  },
  {
    slug: "rf-kill-esp32-c3-supermini",
    name: "RF-KILL ESP32-C3 Super Mini Kit",
    status: "Kit compacto",
    board: "ESP32-C3 Super Mini",
    firmware: "RF-KILL ESP32-C3 SuperMini",
    repoUrl: "https://github.com/pepeangell5/RF-KILL",
    description:
      "Version compacta con ESP32-C3 Super Mini y firmware RF-KILL headless: arranque automatico sin pantalla ni botones para laboratorio educativo controlado.",
    image: "/assets/shop/esp32-c3-supermini-kit.jpg",
    imageAlt: "Kit RF-KILL compacto con ESP32-C3 Super Mini y dos modulos NRF24 PA+LNA con antenas",
    parts: [
      "ESP32-C3 Super Mini",
      "2x nRF24L01+ PA+LNA",
      "Bus SPI compartido para ambos modulos",
      "Bateria 3V",
      "Modulo de carga",
      "Step-up a 5V",
      "Firmware RF-KILL instalado"
    ],
    note: "Ideal cuando buscas una placa mas pequena con arranque automatico para montajes compactos.",
    price: 0,
    currency: "USD",
    stock: 0,
    is_available: false
  }
];
---

<BaseLayout
  title="Tienda"
  description="Kits fisicos programados por PepeAngell Labs con ESP32, NRF24 PA+LNA y firmware instalado para laboratorio educativo controlado."
>
  <section class="section shop-hero">
    <div class="container shop-hero-layout">
      <div class="shop-copy">
        <p class="eyebrow">Lab shop</p>
        <h1>Kits ESP32 programados</h1>
        <p>
          Placas preparadas con firmware RF-KILL para pruebas educativas, laboratorio controlado y aprendizaje
          de hardware embebido. Los pagos se realizan por PayPal y la disponibilidad se confirma antes del envio.
        </p>
        <div class="button-row">
          <a class="button primary" href={sitePath("/shop/checkout/")}>Iniciar pedido</a>
          <a class="button" href={sitePath("/shop/orders/")}>Ver pedido</a>
          <a class="button" href={sitePath("/shop/admin/")}>Admin tienda</a>
          <a class="button" href={telegramChannelUrl} target="_blank" rel="noreferrer noopener">Canal Telegram</a>
          <a class="button" href={telegramGroupUrl} target="_blank" rel="noreferrer noopener">Grupo Telegram</a>
          <a class="button" href={sitePath("/contact/")}>Preguntar disponibilidad</a>
        </div>
      </div>
      <aside class="shop-panel" aria-label="Resumen de compra">
        <p class="status">Flujo manual</p>
        <h2>Checkout + PayPal + Telegram</h2>
        <p>El pedido guarda tus datos de envio, queda pendiente de confirmacion y se paga por PayPal. Pepe confirma por Telegram: @pepeangell.</p>
      </aside>
    </div>
  </section>

  <section class="section compact">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Productos</p>
        <h2>Kits disponibles</h2>
        <p>La disponibilidad, precio y stock se cargan desde Supabase cuando la tienda esta conectada. Si un kit no aparece disponible, confirma por Telegram antes de pagar.</p>
      </div>

      <div class="shop-state" data-shop-state hidden></div>

      <div class="grid shop-grid" data-products-grid>
        {
          products.map((product) => (
            <article class="card shop-card" data-product-slug={product.slug}>
              <img
                class="shop-product-image"
                src={sitePath(product.image)}
                alt={product.imageAlt}
                width="900"
                height="1200"
                loading="lazy"
              />
              <div class="shop-card-top">
                <p class="status">{product.status}</p>
                <span class="shop-chip">{product.board}</span>
              </div>
              <h3>{product.name}</h3>
              <div class="shop-purchase-row">
                <strong class="shop-price">Precio por confirmar</strong>
                <span class="shop-stock">Disponibilidad por confirmar</span>
              </div>
              <div class="shop-firmware">
                <span>Firmware</span>
                <strong>{product.firmware}</strong>
              </div>
              <p>{product.description}</p>

              <div class="shop-parts">
                <p class="small">Incluye:</p>
                <ul>
                  {product.parts.map((part) => <li>{part}</li>)}
                </ul>
              </div>

              <p class="shop-note">{product.note}</p>
              <div class="button-row">
                <a class="button primary" href={sitePath(`/shop/checkout/?product=${product.slug}`)}>Reservar kit</a>
                <a class="button" href={product.repoUrl} target="_blank" rel="noreferrer noopener">Ver firmware</a>
                <a class="button" href={sitePath("/contact/")}>Dudas del kit</a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section compact">
    <div class="container">
      <div class="grid cards">
        <article class="card highlight">
          <p class="status">Proceso</p>
          <h3>Compra simple</h3>
          <p>Completa el checkout, paga por PayPal y envia tu codigo de pedido a @pepeangell en Telegram.</p>
        </article>
        <article class="card">
          <p class="status">Firmware</p>
          <h3>Listo para probar</h3>
          <p>El kit se entrega programado. Puede requerir bateria cargada, antenas conectadas y uso responsable en entorno permitido.</p>
        </article>
        <article class="card">
          <p class="status">Comunidad</p>
          <h3>Telegram ESP32 Tools</h3>
          <p>Sigue avisos, disponibilidad y conversaciones de la comunidad desde Telegram.</p>
          <div class="button-row">
            <a class="button primary" href={telegramChannelUrl} target="_blank" rel="noreferrer noopener">Canal</a>
            <a class="button" href={telegramGroupUrl} target="_blank" rel="noreferrer noopener">Grupo</a>
          </div>
        </article>
        <article class="card">
          <p class="status">Uso responsable</p>
          <h3>Laboratorio controlado</h3>
          <p>Estos kits son para investigacion, aprendizaje y pruebas autorizadas. No se deben usar contra sistemas ajenos.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section compact">
    <div class="container">
      <DisclaimerBanner />
    </div>
  </section>

<script>
  import { formatMoney, normalizeProduct, shopSupabase, shopSupabaseConfigured } from "../../lib/shopSupabase";

  const grid = document.querySelector("[data-products-grid]");
  const state = document.querySelector("[data-shop-state]");

  function escapeHtml(value) {
    return String(value ?? "").replace(/[&<>"']/g, (char) => ({
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#039;"
    })[char]);
  }

  function showState(message, tone = "info") {
    if (!(state instanceof HTMLElement)) return;
    state.textContent = message;
    state.dataset.tone = tone;
    state.hidden = false;
  }

  function productCard(product) {
    const article = document.createElement("article");
    article.className = "card shop-card";
    article.dataset.productSlug = product.slug;

    const normalizedProduct = normalizeProduct(product);
    const parts = Array.isArray(normalizedProduct.parts) ? normalizedProduct.parts : [];
    const repoLink = normalizedProduct.repoUrl
      ? `<a class="button" href="${escapeHtml(normalizedProduct.repoUrl)}" target="_blank" rel="noreferrer noopener">Ver firmware</a>`
      : "";
    const availability = normalizedProduct.isAvailable && normalizedProduct.stock > 0 ? `${normalizedProduct.stock} en stock` : "Por confirmar";
    const reserveClass = normalizedProduct.isAvailable && normalizedProduct.stock > 0 ? "button primary" : "button";
    const reserveLabel = normalizedProduct.isAvailable && normalizedProduct.stock > 0 ? "Reservar kit" : "Consultar";
    const reserveHref = normalizedProduct.isAvailable && normalizedProduct.stock > 0
      ? `/shop/checkout/?product=${encodeURIComponent(normalizedProduct.slug)}`
      : "/contact/";

    article.innerHTML = `
      <img
        class="shop-product-image"
        src="${escapeHtml(normalizedProduct.image)}"
        alt="${escapeHtml(normalizedProduct.imageAlt)}"
        width="900"
        height="1200"
        loading="lazy"
      />
      <div class="shop-card-top">
        <p class="status">${escapeHtml(normalizedProduct.status)}</p>
        <span class="shop-chip">${escapeHtml(normalizedProduct.board)}</span>
      </div>
      <h3>${escapeHtml(normalizedProduct.name)}</h3>
      <div class="shop-purchase-row">
        <strong class="shop-price">${formatMoney(normalizedProduct.price, normalizedProduct.currency)}</strong>
        <span class="shop-stock">${availability}</span>
      </div>
      <div class="shop-firmware">
        <span>Firmware</span>
        <strong>${escapeHtml(normalizedProduct.firmware)}</strong>
      </div>
      <p>${escapeHtml(normalizedProduct.description)}</p>
      <div class="shop-parts">
        <p class="small">Incluye:</p>
        <ul>${parts.map((part) => `<li>${escapeHtml(part)}</li>`).join("")}</ul>
      </div>
      <p class="shop-note">${escapeHtml(normalizedProduct.note)}</p>
      <div class="button-row">
        <a class="${reserveClass}" href="${reserveHref}">${reserveLabel}</a>
        ${repoLink}
        <a class="button" href="/contact/">Dudas del kit</a>
      </div>
    `;

    return article;
  }

  async function loadProducts() {
    if (!shopSupabaseConfigured || !shopSupabase || !(grid instanceof HTMLElement)) {
      showState("Tienda en modo catalogo: falta conectar Supabase para mostrar precio y stock en vivo.");
      return;
    }

    const { data, error } = await shopSupabase
      .from("products")
      .select("id, slug, name, description, firmware_name, repository_url, image_url, price_mxn, stock, active")
      .eq("active", true)
      .order("created_at", { ascending: true });

    if (error) {
      showState("No pude cargar stock en vivo. Puedes consultar disponibilidad por Telegram.", "warning");
      return;
    }

    if (!data?.length) {
      showState("No hay kits marcados como disponibles ahora mismo. Pepe puede activar stock desde el admin.");
      return;
    }

    grid.replaceChildren(...data.map(productCard));
    state?.setAttribute("hidden", "");
  }

  loadProducts();
</script>
</BaseLayout>
