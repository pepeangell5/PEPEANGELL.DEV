---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { sitePath } from "../utils/paths";
import globalStyles from "../styles/global.css?inline";

interface Props {
  title: string;
  description: string;
  robots?: string;
  singleScreen?: boolean;
}

const { title, description, robots, singleScreen = false } = Astro.props;
const pageTitle = title === "ESP32-TOOLS" ? title : `${title} | ESP32-TOOLS`;
const canonical = new URL(Astro.url.pathname, "https://pepeangell.dev").toString();
const goatCounterCode = import.meta.env.PUBLIC_GOATCOUNTER_CODE;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={sitePath("/favicon.ico?v=20260615-2")} sizes="any" />
    <link rel="icon" href={sitePath("/favicon-32.png?v=20260615-2")} type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href={sitePath("/favicon-192.png?v=20260615-2")} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="ESP32-TOOLS" />
    <meta name="theme-color" content="#07090c" />
    <script is:inline>
      (() => {
        try {
          const theme = localStorage.getItem("pepeangell-labs-theme-v1");
          if (theme === "light") document.documentElement.dataset.theme = "light";
        } catch {}
      })();
    </script>
    <style is:inline set:html={globalStyles}></style>
    {
      goatCounterCode && (
        <script
          data-goatcounter={`https://${goatCounterCode}.goatcounter.com/count`}
          async
          src="https://gc.zgo.at/count.js"
        />
      )
    }
  </head>
  <body class={singleScreen ? "single-screen" : undefined}>
    <a class="skip-link" href="#main-content">Saltar al contenido</a>
    <div class="site-shell">
      <Header />
      <main id="main-content">
        <slot />
      </main>
      {!singleScreen && <Footer />}
    </div>
    <script src={sitePath("/scripts/language-toggle.js?v=20260620-1")} defer></script>
  </body>
</html>
