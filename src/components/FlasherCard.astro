---
import Badge from "./Badge.astro";

interface Flasher {
  name: string;
  slug: string;
  board: string;
  display: string;
  modules: string[];
  status: string;
  flasher_url: string;
  github_url: string;
}

interface Props {
  flasher: Flasher;
}

const { flasher } = Astro.props;
---

<article class="card" id={flasher.slug}>
  <p class="status">{flasher.status}</p>
  <h3>{flasher.name}</h3>
  <p><strong>Board:</strong> {flasher.board}</p>
  <p><strong>Display:</strong> {flasher.display}</p>
  <div class="badge-row">
    {flasher.modules.map((moduleName) => <Badge label={moduleName} />)}
  </div>
  <p class="small muted">Flash only compatible hardware. Verifica placa, pantalla, pines y alimentacion antes de usar.</p>
  <div class="button-row">
    <a class="button primary" href={flasher.flasher_url} rel="noreferrer">Firmware / repo</a>
    <a class="button" href={flasher.github_url} rel="noreferrer">GitHub repo</a>
  </div>
</article>
