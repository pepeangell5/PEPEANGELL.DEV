---
import Badge from "./Badge.astro";

interface Flasher {
  name: string;
  slug: string;
  board: string;
  display: string;
  modules: string[];
  status: string;
  flasher_url?: string;
  github_url: string;
}

interface Props {
  flasher: Flasher;
}

const { flasher } = Astro.props;
const flasherTarget = flasher.flasher_url || flasher.github_url;
---

<article class="card" id={flasher.slug}>
  <p class="status">{flasher.status}</p>
  <h3>{flasher.name}</h3>
  <p><strong>Board:</strong> {flasher.board}</p>
  <p><strong>Display:</strong> {flasher.display}</p>
  <div class="badge-row">
    {flasher.modules.map((moduleName) => <Badge label={moduleName} />)}
  </div>
  <p class="small muted">Flash only compatible hardware. Verifica placa, pantalla, pines y alimentación antes de usar.</p>
  <div class="button-row">
    <a class="button primary" href={flasherTarget} target="_blank" rel="noreferrer noopener">Web flasher</a>
    {flasherTarget !== flasher.github_url && <a class="button" href={flasher.github_url} target="_blank" rel="noreferrer noopener">GitHub repo</a>}
  </div>
</article>
