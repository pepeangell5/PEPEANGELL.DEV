---
import { sitePath } from "../utils/paths";
import LanguageToggle from "./LanguageToggle.astro";

const links = [
  { href: "/", label: "Inicio" },
  { href: "/support/", label: "Apoyo" },
  { href: "/firmware/", label: "Firmware" },
  { href: "/shop/", label: "Tienda" },
  { href: "/repos/", label: "Repos" },
  { href: "/flashers/", label: "Flashers" },
  { href: "/hardware/", label: "Hardware" },
  { href: "/downloads/", label: "Descargas" },
  { href: "/code-simulator/", label: "Code Simulator" },
  { href: "/news/", label: "Noticias" },
  { href: "/contact/", label: "Contacto" }
];

const pathname = Astro.url.pathname;
const normalizedPathname = pathname.replace(import.meta.env.BASE_URL.replace(/\/$/, ""), "") || "/";
---

<header class="site-header">
  <div class="container nav">
    <a class="brand" href={sitePath("/")} aria-label="PepeAngell Labs home">
      <img
        class="brand-mark"
        src={sitePath("/assets/mascot-neon-cut.png")}
        alt=""
        width="44"
        height="44"
        aria-hidden="true"
      />
      <span>PepeAngell Labs</span>
    </a>
    <nav class="nav-links" aria-label="Navegacion principal">
      {
        links.map((link) => (
          <a href={sitePath(link.href)} aria-current={normalizedPathname === link.href ? "page" : undefined}>
            {link.label}
          </a>
        ))
      }
    </nav>
    <button class="nav-menu-toggle" type="button" aria-label="Abrir menu" aria-expanded="false" data-nav-toggle>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>
    <LanguageToggle />
  </div>
</header>

<script>
  const toggle = document.querySelector("[data-nav-toggle]");
  const nav = document.querySelector(".nav-links");

  toggle?.addEventListener("click", () => {
    const isOpen = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!isOpen));
    nav?.classList.toggle("open", !isOpen);
  });

  nav?.addEventListener("click", (event) => {
    if (!(event.target instanceof HTMLAnchorElement)) return;
    toggle?.setAttribute("aria-expanded", "false");
    nav.classList.remove("open");
  });
</script>
