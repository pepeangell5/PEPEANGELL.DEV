---
import { sitePath } from "../utils/paths";
import LanguageToggle from "./LanguageToggle.astro";
import ThemeToggle from "./ThemeToggle.astro";

const links = [
  { href: "/", label: "Inicio" },
  { href: "/support/", label: "Apoyo" },
  { href: "/firmware/", label: "Firmware" },
  { href: "/shop/", label: "Tienda" },
  { href: "/repos/", label: "Repos" },
  { href: "/flashers/", label: "Flashers" },
  { href: "/hardware/", label: "Hardware" },
  { href: "/downloads/", label: "Descargas" },
  { href: "/code-simulator/", label: "Code Simulator" },
  { href: "/news/", label: "Noticias" },
  { href: "/contact/", label: "Contacto" }
];

const pathname = Astro.url.pathname;
const normalizedPathname = pathname.replace(import.meta.env.BASE_URL.replace(/\/$/, ""), "") || "/";
---

<header class="site-header">
  <div class="container nav">
    <a class="brand" href={sitePath("/")} aria-label="ESP32-TOOLS home">
      <img
        class="brand-mark"
        src={sitePath("/assets/mascot-esp32-tools-v2.png")}
        alt=""
        width="44"
        height="44"
        aria-hidden="true"
      />
      <span>ESP32-TOOLS</span>
    </a>
    <nav class="nav-links" aria-label="Navegacion principal">
      {
        links.map((link) => (
          <a href={sitePath(link.href)} aria-current={normalizedPathname === link.href ? "page" : undefined}>
            {link.label}
          </a>
        ))
      }
    </nav>
    <button class="nav-menu-toggle" type="button" aria-label="Abrir menu" aria-expanded="false" data-nav-toggle>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>
    <ThemeToggle />
    <LanguageToggle />
  </div>
</header>

<script>
  const toggle = document.querySelector("[data-nav-toggle]");
  const nav = document.querySelector(".nav-links");
  const themeButtons = document.querySelectorAll("[data-theme-option]");
  const themeStorageKey = "pepeangell-labs-theme-v1";

  function setTheme(theme) {
    const normalizedTheme = theme === "light" ? "light" : "dark";
    document.documentElement.dataset.theme = normalizedTheme;

    themeButtons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;
      button.setAttribute("aria-pressed", String(button.dataset.themeOption === normalizedTheme));
    });

    try {
      localStorage.setItem(themeStorageKey, normalizedTheme);
    } catch {}
  }

  try {
    setTheme(localStorage.getItem(themeStorageKey) ?? document.documentElement.dataset.theme ?? "dark");
  } catch {
    setTheme("dark");
  }

  toggle?.addEventListener("click", () => {
    const isOpen = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!isOpen));
    nav?.classList.toggle("open", !isOpen);
  });

  nav?.addEventListener("click", (event) => {
    if (!(event.target instanceof HTMLAnchorElement)) return;
    toggle?.setAttribute("aria-expanded", "false");
    nav.classList.remove("open");
  });

  themeButtons.forEach((button) => {
    button.addEventListener("click", () => {
      if (!(button instanceof HTMLButtonElement)) return;
      setTheme(button.dataset.themeOption);
    });
  });

  document.addEventListener(
    "wheel",
    (event) => {
      const field = event.target;
      if (!(field instanceof HTMLInputElement) || field.type !== "number") return;
      if (document.activeElement !== field) return;
      event.preventDefault();
    },
    { passive: false }
  );
</script>
