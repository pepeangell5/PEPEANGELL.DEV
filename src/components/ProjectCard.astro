---
import Badge from "./Badge.astro";
import { sitePath } from "../utils/paths";

interface Project {
  name: string;
  slug: string;
  description: string;
  tags: string[];
  status: string;
  github_url?: string;
  flasher_url?: string;
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
const flasherHref = project.flasher_url?.startsWith("/") ? sitePath(project.flasher_url) : project.flasher_url;
---

<article class="card">
  <p class="status">{project.status}</p>
  <h3>{project.name}</h3>
  <p>{project.description}</p>
  <div class="badge-row" aria-label={`Tags de ${project.name}`}>
    {project.tags.map((tag) => <Badge label={tag} />)}
  </div>
  <p class="small muted">Uso educativo y en entornos de laboratorio controlados.</p>
  <div class="button-row">
    <a class="button primary" href={sitePath("/firmware/")} target="_blank" rel="noreferrer noopener">Ver README</a>
    {project.github_url && <a class="button" href={project.github_url} target="_blank" rel="noreferrer noopener">GitHub</a>}
    {flasherHref && <a class="button" href={flasherHref} target="_blank" rel="noreferrer noopener">Web Flasher</a>}
  </div>
</article>
