---
import { sitePath } from "../utils/paths";
---

<section class="hero">
  <img
    class="hero-visual"
    src={sitePath("/assets/lab-hero.png")}
    alt="Dark embedded hardware lab bench with ESP32 boards, displays and RF modules"
    width="1600"
    height="900"
  />
  <div class="container hero-content">
    <p class="eyebrow">/root/embedded-lab</p>
    <h1>PepeAngell Labs</h1>
    <p class="hero-subtitle">ESP32 · RF · BLE · WiFi · Cyberdecks · Embedded Projects</p>
    <p class="hero-description">
      Firmware educativo, hardware hacking controlado y herramientas de laboratorio para ESP32, RF, BLE, WiFi,
      displays, cyberdecks y pruebas embebidas autorizadas.
    </p>
    <div class="button-row">
      <a class="button primary" href={sitePath("/projects/")}>View Projects</a>
      <a class="button" href={sitePath("/flashers/")}>Web Flashers</a>
      <a class="button" href="https://github.com/pepeangell5" rel="noreferrer">GitHub</a>
      <a class="button danger" href={sitePath("/disclaimer/")}>Disclaimer</a>
    </div>
  </div>
</section>
