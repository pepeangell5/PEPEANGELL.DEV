---
import { sitePath } from "../utils/paths";
---

<section class="hero">
  <img
    class="hero-visual hero-visual-secondary"
    src={sitePath("/assets/mascot-classic-cut.png")}
    alt=""
    width="980"
    height="1026"
    aria-hidden="true"
  />
  <img
    class="hero-visual hero-visual-primary"
    src={sitePath("/assets/mascot-neon-cut.png")}
    alt="Mascota rosa de PepeAngell Labs con lentes pixelados"
    width="980"
    height="1144"
  />
  <div class="container hero-content">
    <p class="eyebrow">/root/embedded-lab</p>
    <h1>PepeAngell Labs</h1>
    <p class="hero-subtitle">ESP32 · RF · BLE · WiFi · Cyberdecks · Embedded Projects</p>
    <p class="hero-description">
      Firmware educativo, hardware hacking controlado y herramientas de laboratorio para ESP32, RF, BLE, WiFi,
      displays, cyberdecks y pruebas embebidas autorizadas.
    </p>
    <div class="button-row">
      <a class="button primary" href={sitePath("/firmware/")} target="_blank" rel="noreferrer noopener">Ver firmwares</a>
      <a class="button" href={sitePath("/flashers/")} target="_blank" rel="noreferrer noopener">Web Flashers</a>
      <a class="button" href={sitePath("/support/")} target="_blank" rel="noreferrer noopener">Apoyar</a>
      <a class="button" href="https://github.com/pepeangell5" target="_blank" rel="noreferrer noopener">GitHub</a>
      <a class="button danger" href={sitePath("/disclaimer/")} target="_blank" rel="noreferrer noopener">Disclaimer</a>
    </div>
  </div>
</section>
