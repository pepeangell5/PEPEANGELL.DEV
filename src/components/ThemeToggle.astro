<div class="theme-toggle" aria-label="Tema">
  <button type="button" data-theme-option="dark" aria-pressed="true" title="Tema neon oscuro" aria-label="Tema neon oscuro">
    <span class="theme-label-full">Neon</span>
    <span class="theme-label-short" aria-hidden="true">N</span>
  </button>
  <button type="button" data-theme-option="light" aria-pressed="false" title="Tema blanco" aria-label="Tema blanco">
    <span class="theme-label-full">Blanco</span>
    <span class="theme-label-short" aria-hidden="true">B</span>
  </button>
</div>
