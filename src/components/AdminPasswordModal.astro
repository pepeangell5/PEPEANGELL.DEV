<div class="shop-modal-backdrop" data-password-modal hidden>
  <form
    class="card shop-modal shop-password-modal"
    data-password-form
    role="dialog"
    aria-modal="true"
    aria-labelledby="change-password-title"
  >
    <div>
      <p class="eyebrow">Seguridad</p>
      <h2 id="change-password-title">Cambiar contraseña</h2>
      <p>Confirma tu contraseña actual y elige una nueva de al menos 8 caracteres.</p>
    </div>

    <div class="shop-state" data-password-state hidden aria-live="polite"></div>

    <label>
      Contraseña actual
      <input
        class="field"
        name="current_password"
        type="password"
        autocomplete="current-password"
        minlength="6"
        maxlength="72"
        required
      />
    </label>

    <label>
      Nueva contraseña
      <input
        class="field"
        name="new_password"
        type="password"
        autocomplete="new-password"
        minlength="8"
        maxlength="72"
        required
      />
    </label>

    <label>
      Confirmar nueva contraseña
      <input
        class="field"
        name="confirm_password"
        type="password"
        autocomplete="new-password"
        minlength="8"
        maxlength="72"
        required
      />
    </label>

    <div class="button-row">
      <button class="button primary" type="submit" data-password-submit>Guardar contraseña</button>
      <button class="button" type="button" data-password-cancel>Cancelar</button>
    </div>
  </form>
</div>

<style>
  .shop-password-modal {
    display: grid;
    border-color: rgba(57, 255, 136, 0.38);
  }

  .shop-password-modal > div:first-child {
    display: grid;
    gap: 6px;
  }

  .shop-password-modal label {
    display: grid;
    gap: 6px;
    color: var(--text);
    font-weight: 750;
  }

  :global(html[data-theme="light"]) .shop-password-modal {
    border-color: rgba(255, 44, 169, 0.34);
  }
</style>
